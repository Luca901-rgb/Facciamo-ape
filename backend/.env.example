# MongoDB Atlas connection string
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority

# Database name on MongoDB
DB_NAME=facciamoape

# Emergent integrations (object storage + OAuth backend)
EMERGENT_LLM_KEY=your_emergent_key

# App identifier used for uploaded file paths
APP_NAME=facciamoape

# Comma-separated Netlify frontend URL(s), e.g. https://facciamoape.netlify.app
CORS_ORIGINS=https://your-site.netlify.app,http://localhost:3000

# Comma-separated admin emails (auto is_admin on login)
ADMIN_EMAILS=you@example.com
